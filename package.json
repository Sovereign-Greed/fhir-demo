{
  "name": "fhri-migration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:check": "tsx scripts/db-check.ts",
    "fhir:check": "tsx scripts/fhir-check.ts",
    "migrate:check": "tsx scripts/migrate-check.ts",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:dev": "tsx scripts/migrate.ts --limit 20",
    "migrate:resume": "tsx scripts/migrate.ts --resume"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
